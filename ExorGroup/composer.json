{
    "name": "exorgroup/apex",
    "description": "APEX admin interface framework for Laravel",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Your Name",
            "email": "your.email@example.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "laravel/framework": "^10.0|^11.0|^12.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "orchestra/testbench": "^8.0"
    },
    "autoload": {
        "psr-4": {
            "ExorGroup\\Apex\\": "./"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ExorGroup\\Apex\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "ExorGroup\\Apex\\ApexServiceProvider"
            ],
            "aliases": {
                "Apex": "ExorGroup\\Apex\\Facades\\Apex"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}